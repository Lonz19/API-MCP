run = "pip install -r requirements.txt && uvicorn app.main:app --host 0.0.0.0 --port 8000"
language = "python3"
entrypoint = "app/main.py"
modules = ["python-3.11"]

[nix]
channel = "stable-24_05"
packages = ["libxcrypt"]

[deployment]
run = ["sh", "-c", "pip install -r requirements.txt && uvicorn app.main:app --host 0.0.0.0 --port 8000"]

[[ports]]
localPort = 8000
externalPort = 80
